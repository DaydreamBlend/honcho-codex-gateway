# Gateway mode: fake for tests, live for Codex OAuth backend.
CODEX_GATEWAY_MODE=fake
CODEX_GATEWAY_REASONING_EFFORT=medium
CODEX_BACKEND_BASE_URL=https://chatgpt.com/backend-api/codex

# Local gateway API key checked against Authorization: Bearer ***.
# If set, auth is required by default.
GATEWAY_API_KEY=change-me-random-local-secret

# Embeddings: proxy = forward /v1/embeddings to the bundled llama.cpp GGUF backend.
EMBEDDING_BACKEND=proxy
EMBEDDING_BASE_URL=http://embedding-server:8080/v1
EMBEDDING_MODEL=text-embedding-bge-m3
EMBEDDING_GGUF_PATH=./models/bge-m3-FP16.gguf
REQUEST_TIMEOUT_SECONDS=120

# Codex OAuth store inside container.
CODEX_AUTH_DIR=/data/codex-auth
